+            Email = adminEmail,
+            FullName = "Platform Admin",
+            PreferredLanguage = "ar",
+            Role = UserRole.Admin,
+            EmailConfirmed = true
+        };
+
+        var createResult = await userManager.CreateAsync(adminUser, adminPassword);
